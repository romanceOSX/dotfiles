# .envrc — machine-local env for this repo.
#
# Loads a gitignored ./.env (API keys / tokens) with ZERO Nix evaluation, so
# editing a credential takes effect immediately in new shells.
#
# We intentionally do NOT `use flake` here. That would realize the flake's
# inputs (including the private work-dotfiles input) and load a devShell on
# every entry into this dir — unnecessary per-shell overhead, and a hard error
# on any host that lacks work-dotfiles access (which would discard .env too).
# If you want the sops/age dev shell, run `nix develop` by hand.
dotenv_if_exists .env
