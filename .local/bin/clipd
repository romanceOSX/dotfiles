#!/usr/bin/env bash
# Clipboard history daemon.
# macOS: starts the CopyQ server (.app bundle) if not already running.
# Linux: pipes wl-paste clipboard change events into cliphist store.
# Linux instance is guarded by a PID file to prevent duplicates.

if [[ "$(uname)" == Darwin ]]; then
  copyq count >/dev/null 2>&1 && exit 0  # server already up
  for app_dir in \
    "$HOME/.nix-profile/Applications" \
    "/etc/profiles/per-user/$USER/Applications" \
    "$HOME/Applications" \
    "/Applications"; do
    if [[ -d "$app_dir/CopyQ.app" ]]; then
      open "$app_dir/CopyQ.app"
      exit 0
    fi
  done
  exit 1
fi

CLIPH_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/cliph"
PIDFILE="$CLIPH_DIR/daemon.pid"
mkdir -p "$CLIPH_DIR"

if [[ -f "$PIDFILE" ]]; then
  pid=$(< "$PIDFILE")
  kill -0 "$pid" 2>/dev/null && exit 0
fi
echo $$ > "$PIDFILE"
trap 'rm -f "$PIDFILE"' EXIT INT TERM

wl-paste --watch cliphist store
