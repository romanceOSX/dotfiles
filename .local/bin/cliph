#!/usr/bin/env bash
# Clipboard history picker.
# macOS: reads entries from ~/.local/share/cliph/ (written by clipd).
# Linux: uses cliphist + wl-copy.
# Set CLIPH_PRINT=1 to write selection to stdout (used by the zsh ^Y widget).

CLIPH_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/cliph"

if [[ "$(uname)" == Darwin ]]; then
  if [[ ! -s "$CLIPH_DIR/history" ]]; then
    printf 'No clipboard history yet — is clipd running?\n' >&2
    exit 1
  fi
  selected=$(tac "$CLIPH_DIR/history" \
    | fzf --prompt 'cliph> ' --no-sort \
        --delimiter=$'\t' --with-nth=2..) \
    || exit 0
  ts=$(printf '%s' "$selected" | cut -f1)
  if [[ ! -f "$CLIPH_DIR/entries/$ts" ]]; then
    printf 'Entry missing: %s\n' "$ts" >&2; exit 1
  fi
  if [[ "${CLIPH_PRINT:-0}" == 1 ]]; then
    cat "$CLIPH_DIR/entries/$ts"
  else
    pbcopy < "$CLIPH_DIR/entries/$ts"
  fi
else
  _copy() {
    if [[ "${CLIPH_PRINT:-0}" == 1 ]]; then cat; else wl-copy; fi
  }
  cliphist list \
    | fzf --prompt 'cliph> ' \
        --delimiter=$'\t' --with-nth=2.. \
    | cliphist decode \
    | _copy
fi
