#!/usr/bin/env bash
# Clipboard history picker.
# macOS: uses CopyQ's CLI (copyq eval/read/select).
# Linux: uses cliphist + wl-copy.
# Set CLIPH_PRINT=1 to write selection to stdout (used by the zsh ^Y widget).

if [[ "$(uname)" == Darwin ]]; then
  selected=$(copyq eval -- \
    'var o="";for(var i=0;i<count();i++){var t=str(read(i));o+=i+"\t"+t.split("\n")[0].substring(0,200)+"\n";}print(o);' \
    2>/dev/null \
    | fzf --prompt 'cliph> ' --delimiter=$'\t' --with-nth=2..) \
    || exit 0
  idx=$(printf '%s' "$selected" | cut -f1)
  if [[ "${CLIPH_PRINT:-0}" == 1 ]]; then
    copyq read "$idx"
  else
    copyq select "$idx"
  fi
else
  _copy() {
    if [[ "${CLIPH_PRINT:-0}" == 1 ]]; then cat; else wl-copy; fi
  }
  cliphist list \
    | fzf --prompt 'cliph> ' \
        --delimiter=$'\t' --with-nth=2.. \
    | cliphist decode \
    | _copy
fi
