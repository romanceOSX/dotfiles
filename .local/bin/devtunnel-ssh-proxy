#!/usr/bin/env bash
# Connects netcat to a devtunnel and cleans up the devtunnel when done
TUNNEL_NAME="$1"

tmpout="/tmp/devtunnel-ssh.log"
# Run devtunnel and redirect output
devtunnel connect "$TUNNEL_NAME" > "$tmpout" 2>&1 &
TUNNEL_PID=$!

# Cleanup on exit (don't delete the log file so we can read it later)
trap 'kill $TUNNEL_PID 2>/dev/null' EXIT INT TERM

PORT=""
for i in {1..60}; do
    PORT=$(grep "Forwarding from" "$tmpout" | sed -n 's/.*127\.0\.0\.1:\([0-9]*\).*/\1/p' | head -n 1)
    if [ -n "$PORT" ]; then
        break
    fi
    if ! kill -0 $TUNNEL_PID 2>/dev/null; then
        echo "devtunnel process died. Output:" >&2
        cat "$tmpout" >&2
        exit 1
    fi
    sleep 0.2
done

if [ -z "$PORT" ]; then
    echo "Timed out waiting for devtunnel port. Output:" >&2
    cat "$tmpout" >&2
    exit 1
fi

nc 127.0.0.1 "$PORT"
