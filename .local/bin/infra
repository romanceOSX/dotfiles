#!/usr/bin/env bash
# infra — run the infrastructure tools (Portainer, Paisa, Dozzle)
#
# Runs the docker-compose stack generated by home/infra.nix.
#
# Usage: infra {up|down|restart|status|logs|pull}
set -euo pipefail

stack="infra"
conf_dir="${XDG_CONFIG_HOME:-$HOME/.config}/infra"

usage() {
  echo "usage: infra {up|down|restart|status|logs|pull}" >&2
  exit 2
}

need_docker() {
  command -v docker >/dev/null 2>&1 || {
    echo "infra: docker not found on PATH." >&2; exit 1; }
  docker info >/dev/null 2>&1 || {
    echo "infra: docker daemon not reachable — is dockerd running?" >&2
    exit 1
  }
}

cmd="${1:-status}"
case "$cmd" in
  up)
    need_docker
    # Ensure external volume exists for portainer
    docker volume ls | grep -q portainer_data || docker volume create portainer_data >/dev/null
    cd "$conf_dir"
    docker compose -p "$stack" up -d
    echo "infra: services up!"
    ;;
  down)
    need_docker
    cd "$conf_dir"
    docker compose -p "$stack" down
    echo "infra: services stopped"
    ;;
  restart)
    "$0" down
    "$0" up
    ;;
  status)
    need_docker
    cd "$conf_dir"
    docker compose -p "$stack" ps
    ;;
  logs)
    need_docker
    cd "$conf_dir"
    exec docker compose -p "$stack" logs -f
    ;;
  pull)
    need_docker
    cd "$conf_dir"
    docker compose -p "$stack" pull
    ;;
  *)
    usage
    ;;
esac
