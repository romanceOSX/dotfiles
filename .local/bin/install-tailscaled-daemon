#!/usr/bin/env sh

# Installs a boot-time service that runs the Nix-provided tailscaled, pointed at
# the stable ~/.nix-profile symlink so `home-manager switch` upgrades don't break
# the daemon (unlike pointing at /nix/store/... directly).
#
#   macOS  -> /Library/LaunchDaemons/com.tailscale.tailscaled.plist  (launchd)
#   Linux  -> /etc/systemd/system/tailscaled.service                 (systemd)
#
# Requires sudo. Run once per machine. After install, run `tailscale up`.

set -e

TAILSCALED="$HOME/.nix-profile/bin/tailscaled"
TAILSCALE="$HOME/.nix-profile/bin/tailscale"

if [ ! -x "$TAILSCALED" ]; then
    echo "error: $TAILSCALED not found (is tailscale in home.packages?)" >&2
    exit 1
fi

sudo mkdir -p /var/lib/tailscale

install_macos() {
    PLIST=/Library/LaunchDaemons/com.tailscale.tailscaled.plist

    sudo tee "$PLIST" >/dev/null <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.tailscale.tailscaled</string>
    <key>ProgramArguments</key>
    <array>
        <string>$TAILSCALED</string>
        <string>--state=/var/lib/tailscale/tailscaled.state</string>
        <string>--socket=/var/run/tailscaled.socket</string>
        <string>--port=41641</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/var/log/tailscaled.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/tailscaled.log</string>
</dict>
</plist>
EOF

    sudo launchctl bootout system "$PLIST" 2>/dev/null || true
    sudo launchctl bootstrap system "$PLIST"
}

install_systemd() {
    if [ ! -d /run/systemd/system ]; then
        echo "error: systemd is not running (PID 1 is not systemd)." >&2
        echo "On WSL, add the following to /etc/wsl.conf:" >&2
        echo "    [boot]" >&2
        echo "    systemd=true" >&2
        echo "then restart the distro ('wsl --shutdown') and re-run this script." >&2
        exit 1
    fi

    UNIT=/etc/systemd/system/tailscaled.service

    sudo tee "$UNIT" >/dev/null <<EOF
[Unit]
Description=Tailscale node agent
Documentation=https://tailscale.com/kb/
After=network-pre.target
Wants=network-pre.target

[Service]
ExecStart=$TAILSCALED \\
  --state=/var/lib/tailscale/tailscaled.state \\
  --socket=/run/tailscale/tailscaled.sock \\
  --port=41641
RuntimeDirectory=tailscale
RuntimeDirectoryMode=0755
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

    # daemon-reload can exit non-zero on systems that have stale linked unit
    # files (e.g. a spurious /etc/systemd/system/sshd.service symlink left by
    # openssh packages on Ubuntu). Those errors don't affect tailscaled — check
    # that the reload actually registered our new unit instead of failing fast.
    sudo systemctl daemon-reload 2>&1 | grep -v 'linked unit file' >&2 || true
    if ! systemctl cat tailscaled.service >/dev/null 2>&1; then
        echo "error: daemon-reload did not register tailscaled.service" >&2
        exit 1
    fi
    sudo systemctl enable tailscaled
    sudo systemctl restart tailscaled

    # Allow the invoking user to run `tailscale` without sudo. The CLI lives in
    # the user's Nix profile, which root's secure_path PATH can't see — so set
    # the operator now (using absolute paths) instead of needing `sudo tailscale`
    # later. Wait briefly for the socket to come up after restart.
    for _ in 1 2 3 4 5; do
        [ -S /run/tailscale/tailscaled.sock ] && break
        sleep 1
    done
    sudo "$TAILSCALE" set --operator="$(id -un)" 2>/dev/null \
        || echo "note: could not set operator; run 'tailscale up' to finish setup." >&2
}

case "$(uname)" in
    Darwin) install_macos ;;
    Linux)  install_systemd ;;
    *)
        echo "error: unsupported OS '$(uname)'." >&2
        exit 1
        ;;
esac

echo "tailscaled daemon installed and started."
if [ "$(uname)" = "Linux" ]; then
    echo "Run 'tailscale up' to authenticate this machine (no sudo needed)."
else
    echo "Run 'sudo tailscale up' to authenticate this machine."
fi
