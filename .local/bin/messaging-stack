#!/usr/bin/env bash
# messaging-stack — manage the WeeChat + Matrix messaging backend on alien.
#
# WeeChat connects (via the Matrix plugin) to a Conduit homeserver running on
# the always-on `alien` Tailscale node. Two mautrix bridges connect Conduit to
# WhatsApp and Discord. All three run as systemd user services on alien — no
# Docker, no VMs, no battery drain on macOS.
#
#   WeeChat ──Matrix──► Conduit ──► mautrix-whatsapp ──► WhatsApp Web
#     (Mac)                     └──► mautrix-discord  ──► Discord API
#   (localhost:6167 via tunnel)                 (all running on alien)
#
# Usage:
#   messaging-stack setup [--host=alien|local]    first-time bootstrap
#   messaging-stack start|stop|restart [--host=…] service lifecycle
#   messaging-stack status [--host=…]             show service state
#   messaging-stack logs [--host=…]               tail journald logs
#   messaging-stack tunnel                        SSH-forward alien:6167 here
#   messaging-stack login-whatsapp                print WhatsApp login steps
#   messaging-stack login-discord                 print Discord login steps
#
# Default host is `alien`. Pass --host=local to run locally instead (services
# must already be installed as systemd units via home-manager switch).
set -euo pipefail

# --- config ----------------------------------------------------------------
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/messaging"
DATA_DIR="${MESSAGING_DATA:-$HOME/.local/share/messaging}"

SERVER_NAME="${MATRIX_SERVER_NAME:-localhost}"
MATRIX_USER="${MATRIX_USER:-$USER}"
USER_ID="@${MATRIX_USER}:${SERVER_NAME}"
CONDUIT_PORT=6167

ALIEN_HOST="${MESSAGING_ALIEN_HOST:-alien}"

SERVICES=(matrix-conduit mautrix-whatsapp mautrix-discord)

# --- pretty output ---------------------------------------------------------
c_head=$'\033[38;2;197;142;167m'   # mauve
c_ok=$'\033[38;2;180;250;158m'     # green
c_warn=$'\033[38;2;246;207;148m'   # peach
c_dim=$'\033[38;2;126;116;128m'    # grey
c_off=$'\033[0m'
say()  { printf '%s%s%s\n' "$c_head" "$*" "$c_off"; }
ok()   { printf '%s✓ %s%s\n' "$c_ok" "$*" "$c_off"; }
warn() { printf '%s! %s%s\n' "$c_warn" "$*" "$c_off"; }
dim()  { printf '%s%s%s\n' "$c_dim" "$*" "$c_off"; }
die()  { printf '%sError: %s%s\n' $'\033[38;2;255;179;179m' "$*" "$c_off" >&2; exit 1; }

# --- systemctl wrapper -----------------------------------------------------
ctl() { systemctl --user "$@"; }

require_services() {
  ctl list-unit-files matrix-conduit.service >/dev/null 2>&1 \
    || die "systemd unit matrix-conduit.service not found — run: nix-deploy alien"
}

# Render a __TOKEN__ template to a destination file.
render() {
  local src="$1" dst="$2"; shift 2
  local content; content="$(cat "$src")"
  while [ "$#" -gt 0 ]; do
    local key="$1" val="$2"; shift 2
    content="${content//$key/$val}"
  done
  printf '%s\n' "$content" > "$dst"
}

# ---------------------------------------------------------------------------
# setup — generate configs, register bridges with Conduit, start services
# ---------------------------------------------------------------------------
cmd_setup() {
  require_services
  say "Setting up the Matrix messaging stack (server: ${SERVER_NAME}, user: ${USER_ID})"

  mkdir -p "${DATA_DIR}/conduit/db" "${DATA_DIR}/whatsapp" "${DATA_DIR}/discord"

  # Make sure linger is on so user services survive logout.
  loginctl enable-linger "$USER" 2>/dev/null || true

  # Render Conduit config — substitute both SERVER_NAME and the runtime data dir path.
  render "${CONFIG_DIR}/conduit.toml.template" "${DATA_DIR}/conduit/conduit.toml" \
    "__SERVER_NAME__" "${SERVER_NAME}" \
    "__DATA_DIR__"    "${DATA_DIR}"
  ok "rendered conduit.toml"

  # Render bridge configs (tokens are placeholders; --generate-registration fills them in).
  render "${CONFIG_DIR}/whatsapp.yaml.template" "${DATA_DIR}/whatsapp/config.yaml" \
    "__SERVER_NAME__" "${SERVER_NAME}" "__USER_ID__" "${USER_ID}"
  ok "rendered whatsapp/config.yaml"

  render "${CONFIG_DIR}/discord.yaml.template" "${DATA_DIR}/discord/config.yaml" \
    "__SERVER_NAME__" "${SERVER_NAME}" "__USER_ID__" "${USER_ID}"
  ok "rendered discord/config.yaml"

  # Generate appservice registration files from the bridge binaries. This also
  # writes real tokens back into config.yaml so the bridges can authenticate.
  say "Generating bridge registrations..."
  local wa_bin dc_bin
  wa_bin=$(systemctl --user cat mautrix-whatsapp.service | grep ExecStart= | sed 's|ExecStart=||;s| .*||')
  dc_bin=$(systemctl --user cat mautrix-discord.service  | grep ExecStart= | sed 's|ExecStart=||;s| .*||')

  "$wa_bin" -g \
    -c "${DATA_DIR}/whatsapp/config.yaml" \
    -r "${DATA_DIR}/whatsapp/registration.yaml" 2>&1 | grep -v '^$' || true
  ok "whatsapp registration.yaml generated"

  "$dc_bin" -g \
    -c "${DATA_DIR}/discord/config.yaml" \
    -r "${DATA_DIR}/discord/registration.yaml" 2>&1 | grep -v '^$' || true
  ok "discord registration.yaml generated"

  # Copy registrations into Conduit's data dir so it can load them.
  cp "${DATA_DIR}/whatsapp/registration.yaml" "${DATA_DIR}/conduit/whatsapp-registration.yaml"
  cp "${DATA_DIR}/discord/registration.yaml"  "${DATA_DIR}/conduit/discord-registration.yaml"
  ok "registrations copied to Conduit data dir"

  # Start Conduit first, then bridges.
  say "Starting services..."
  ctl start matrix-conduit
  sleep 3
  ctl start mautrix-whatsapp mautrix-discord
  sleep 2
  ok "all services started"

  print_next_steps
}

print_next_steps() {
  cat <<EOF

$(say "Stack is up. Three one-time steps to finish:")

$(dim "1. Open the tunnel from your Mac (keep it in a tmux pane):")
     messaging-stack tunnel

$(dim "2. Connect WeeChat to the local Matrix server:")
     weechat
       /script install vim_mode.py
       /matrix server add local localhost:${CONDUIT_PORT}
       /matrix connect local
       /matrix register ${MATRIX_USER} <choose-a-password>

$(dim "3. Log in to WhatsApp and Discord:")
     messaging-stack login-whatsapp
     messaging-stack login-discord

$(ok "Bridge registration with Conduit was handled automatically above.")
EOF
}

# ---------------------------------------------------------------------------
# lifecycle
# ---------------------------------------------------------------------------
cmd_start()   { require_services; ctl start   "${SERVICES[@]}"; ok "services started"; connect_hint; }
cmd_stop()    { require_services; ctl stop    "${SERVICES[@]}"; ok "services stopped"; }
cmd_restart() { require_services; ctl restart "${SERVICES[@]}"; ok "services restarted"; }

cmd_status() {
  require_services
  ctl status "${SERVICES[@]}" --no-pager 2>&1 || true
  connect_hint
}

cmd_logs() {
  require_services
  journalctl --user -u matrix-conduit -u mautrix-whatsapp -u mautrix-discord -f --no-hostname
}

connect_hint() {
  echo
  dim "Mac:  messaging-stack tunnel   then   weechat → /matrix connect local"
}

# ---------------------------------------------------------------------------
# tunnel — forward alien's Conduit port to localhost on this machine
# ---------------------------------------------------------------------------
cmd_tunnel() {
  say "Forwarding ${ALIEN_HOST}:${CONDUIT_PORT} → localhost:${CONDUIT_PORT}"
  dim "Leave this running (Ctrl-C to stop), then /matrix connect local in WeeChat."
  exec ssh -N -L "${CONDUIT_PORT}:localhost:${CONDUIT_PORT}" "${ALIEN_HOST}"
}

# ---------------------------------------------------------------------------
# login helpers
# ---------------------------------------------------------------------------
cmd_login_whatsapp() {
  cat <<EOF
$(say "Link WhatsApp")
$(dim "In WeeChat, open a chat with the bridge bot and request a QR login:")
     /query @whatsappbot:${SERVER_NAME}
       login

$(dim "A QR code appears in the buffer. On your phone:")
$(dim "  WhatsApp → Settings → Linked Devices → Link a Device → scan it.")
EOF
}

cmd_login_discord() {
  cat <<EOF
$(say "Link Discord")
$(dim "In WeeChat, open a chat with the bridge bot:")
     /query @discordbot:${SERVER_NAME}
       login-qr        # scan with Discord mobile app (safer), OR
       login-token user <your-token>

$(dim "Once linked, bridge your guilds with:  guilds bridge <guild-id>")
EOF
}

# ---------------------------------------------------------------------------
# arg parsing + delegation
# ---------------------------------------------------------------------------
HOST=alien
SUBCMD=""
for arg in "$@"; do
  case "$arg" in
    --host=*) HOST="${arg#--host=}" ;;
    -h|--help) SUBCMD="help" ;;
    *) [ -z "$SUBCMD" ] && SUBCMD="$arg" ;;
  esac
done

# When host is alien, delegate all service-management commands there via SSH.
# Always pass --host=local so the remote invocation runs in-place.
if [ "$HOST" = "alien" ]; then
  case "$SUBCMD" in
    tunnel|login-whatsapp|login-discord|help|"")
      : ;; # handled locally below
    *)
      say "Running '$SUBCMD' on ${ALIEN_HOST}..."
      exec ssh "${ALIEN_HOST}" "messaging-stack $SUBCMD --host=local"
      ;;
  esac
fi

case "$SUBCMD" in
  setup)           cmd_setup ;;
  start)           cmd_start ;;
  stop)            cmd_stop ;;
  restart)         cmd_restart ;;
  status)          cmd_status ;;
  logs)            cmd_logs ;;
  tunnel)          cmd_tunnel ;;
  login-whatsapp)  cmd_login_whatsapp ;;
  login-discord)   cmd_login_discord ;;
  help|"")
    sed -n '3,28p' "$0" | sed 's/^# \{0,1\}//'
    ;;
  *) die "unknown command: $SUBCMD (try: messaging-stack help)" ;;
esac
