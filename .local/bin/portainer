#!/usr/bin/env bash
# portainer — run the Portainer CE container (the docker management web UI).
#
# Portainer ships only as a docker image (no nixpkgs package exists), so it runs
# as a container rather than a nix-installed binary. This works anywhere a docker
# daemon is reachable: macOS via colima, or a Linux host running the distro's
# dockerd (the enableDocker hosts). Home Manager only installs this launcher on
# docker-enabled machines (see home/portainer.nix).
#
# The container uses --restart=unless-stopped, so once started it comes back with
# the docker daemon across reboots without needing a systemd service (which
# wouldn't work on macOS anyway).
#
# Usage: portainer {start|stop|restart|status|logs|update}
#   portainer start     # create/start the container → https://localhost:9443
#   portainer stop      # stop it (kept for a fast restart)
#   portainer update    # pull latest image + recreate
set -euo pipefail

name=portainer
image=portainer/portainer-ce:latest
data=portainer_data

usage() {
  echo "usage: portainer {start|stop|restart|status|logs|update}" >&2
  exit 2
}

need_docker() {
  command -v docker >/dev/null 2>&1 || {
    echo "portainer: docker not found on PATH." >&2; exit 1; }
  docker info >/dev/null 2>&1 || {
    echo "portainer: docker daemon not reachable — start it first" >&2
    echo "           (macOS: 'colima start'; Linux: 'systemctl --user status' / system dockerd)." >&2
    exit 1
  }
}

exists() { docker ps -a --format '{{.Names}}' | grep -qx "$name"; }

cmd="${1:-status}"
case "$cmd" in
  start)
    need_docker
    if exists; then
      docker start "$name" >/dev/null
    else
      docker run -d --name "$name" --restart=unless-stopped \
        -p 9443:9443 -p 8000:8000 \
        -v /var/run/docker.sock:/var/run/docker.sock \
        -v "$data":/data \
        "$image" >/dev/null
    fi
    echo "portainer: up → https://localhost:9443"
    ;;
  stop)
    need_docker
    docker stop "$name" >/dev/null 2>&1 || true
    echo "portainer: stopped"
    ;;
  restart)
    "$0" stop
    "$0" start
    ;;
  status)
    need_docker
    if exists; then
      docker ps -a --filter "name=^/${name}$" \
        --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'
    else
      echo "portainer: not created (run 'portainer start')"
    fi
    ;;
  logs)
    need_docker
    exec docker logs -f "$name"
    ;;
  update)
    need_docker
    docker pull "$image"
    docker rm -f "$name" >/dev/null 2>&1 || true
    "$0" start
    ;;
  *)
    usage
    ;;
esac
