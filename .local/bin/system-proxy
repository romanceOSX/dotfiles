#!/usr/bin/env bash
# system-proxy — the box's single system-wide nginx reverse proxy (tier1).
#
# The only thing bound to this host's real 0.0.0.0:80/443. Terminates TLS with
# one mkcert wildcard cert for ROOT_DOMAIN and fans out by Host header to each
# project's own loopback-published port. Each project keeps owning its own
# internal routing/TLS — this proxy never shares a docker network with any of
# them, they stay fully independent compose projects.
#
# Runs with --network host: every backend it fronts publishes to 127.0.0.1
# only (not 0.0.0.0), which refuses connections arriving via the docker0
# bridge gateway (host.docker.internal) — only genuine host loopback works.
# --network host makes this container's own 127.0.0.1 that real loopback, no
# bridge hop involved. That also means it needs no ufw carve-out (unlike
# meddy's own bridge-networked nginx reaching the host API on :3000) —
# loopback traffic already bypasses ufw's INPUT chain entirely.
#
# Config (conf.d/default.conf) and ROOT_DOMAIN are nix-rendered by
# home/system-proxy.nix into ~/.config/system-proxy/. The TLS cert is NOT
# nix-managed (mkcert writes host-local state under ~/.local/state) — run
# `system-proxy certs` once, then `system-proxy start`.
#
# --restart=unless-stopped means it comes back after a reboot on its own, same
# as the tsvc/portainer containers, as long as dockerd itself is enabled
# (already true on server hosts).
#
# Usage: system-proxy {certs|start|stop|restart|reload|status|logs|update}
set -euo pipefail

name=system-proxy
image=nginx:1-alpine
conf_dir="${XDG_CONFIG_HOME:-$HOME/.config}/system-proxy"
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/system-proxy"
cert_dir="$state_dir/certs"
config_env="$conf_dir/config.env"

usage() {
  echo "usage: system-proxy {certs|start|stop|restart|reload|status|logs|update}" >&2
  exit 2
}

need_docker() {
  command -v docker >/dev/null 2>&1 || {
    echo "system-proxy: docker not found on PATH." >&2; exit 1; }
  docker info >/dev/null 2>&1 || {
    echo "system-proxy: docker daemon not reachable — is dockerd running?" >&2
    echo "              (Linux: 'sudo systemctl status docker')." >&2
    exit 1
  }
}

load_root_domain() {
  ROOT_DOMAIN=""
  # shellcheck disable=SC1090
  [ -r "$config_env" ] && . "$config_env"
  [ -n "$ROOT_DOMAIN" ] || {
    echo "system-proxy: ROOT_DOMAIN unset — is $config_env present? (run hm-switch)" >&2
    exit 1
  }
}

exists() { docker ps -a --format '{{.Names}}' | grep -qx "$name"; }

cmd_certs() {
  command -v mkcert >/dev/null 2>&1 || {
    echo "system-proxy: mkcert not found on PATH." >&2; exit 1; }
  load_root_domain
  mkdir -p "$cert_dir"
  mkcert -install
  mkcert -cert-file "$cert_dir/proxy.pem" -key-file "$cert_dir/proxy-key.pem" \
    "*.$ROOT_DOMAIN" "$ROOT_DOMAIN"
  echo "system-proxy: cert for *.$ROOT_DOMAIN written to $cert_dir"
}

cmd="${1:-status}"
case "$cmd" in
  certs) cmd_certs ;;
  start)
    need_docker
    load_root_domain
    [ -f "$cert_dir/proxy.pem" ] || {
      echo "system-proxy: no cert — run 'system-proxy certs' first." >&2; exit 1; }
    [ -d "$conf_dir/conf.d" ] || {
      echo "system-proxy: no rendered config at $conf_dir/conf.d — run hm-switch first." >&2
      exit 1
    }
    if exists; then
      docker start "$name" >/dev/null
    else
      # conf.d/default.conf is a symlink chain into /nix/store (Home Manager's
      # normal file layout). Rather than resolving it (the final hop is a bare
      # store path with no directory of its own to scope a mount to), just
      # also mount /nix/store itself at the same path — the existing symlinks
      # then resolve inside the container exactly as they do on the host.
      docker run -d --name "$name" --restart=unless-stopped \
        --network host \
        -v "$conf_dir/conf.d:/etc/nginx/conf.d:ro" \
        -v /nix/store:/nix/store:ro \
        -v "$cert_dir:/etc/nginx/certs:ro" \
        "$image" >/dev/null
    fi
    echo "system-proxy: up → https://$ROOT_DOMAIN (and *.${ROOT_DOMAIN})"
    ;;
  stop)
    need_docker
    docker stop "$name" >/dev/null 2>&1 || true
    echo "system-proxy: stopped"
    ;;
  restart)
    "$0" stop
    "$0" start
    ;;
  reload)
    need_docker
    docker exec "$name" nginx -s reload
    echo "system-proxy: config reloaded"
    ;;
  status)
    need_docker
    if exists; then
      docker ps -a --filter "name=^/${name}$" \
        --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'
    else
      echo "system-proxy: not created (run 'system-proxy start')"
    fi
    ;;
  logs)
    need_docker
    exec docker logs -f "$name"
    ;;
  update)
    need_docker
    docker pull "$image"
    docker rm -f "$name" >/dev/null 2>&1 || true
    "$0" start
    ;;
  *)
    usage
    ;;
esac
