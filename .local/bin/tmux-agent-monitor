#!/usr/bin/env bash
# tmux-agent-monitor вЂ” K8s-style AI agent session manager
#
# Lists every claude / copilot tmux session (running or idle).
# Select an entry to switch to it; pick a "new" line to spawn one.
# Navigate with the standard schema: ctrl-j/k, tab, enter, esc.
#
# Called via:  tmux display-popup -E 'tmux-agent-monitor'

FZF_NAV="--bind=ctrl-j:down,ctrl-k:up,ctrl-n:down,ctrl-p:up,ctrl-y:accept,tab:accept"

# Pastel-rainbow palette (matches the theme)
PINK=$'\e[38;2;197;142;167m'
GREEN=$'\e[38;2;180;250;158m'
DIM=$'\e[2m'
BOLD=$'\e[1m'
RESET=$'\e[0m'

# в”Ђв”Ђ Detect active agent processes (one tmux call) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# awk: for each pane with a claude/copilot command, print "session agent"
active=$(tmux list-panes -a \
    -F '#{session_name} #{pane_current_command}' 2>/dev/null | \
    awk '$2 ~ /^claude/  { print $1, "claude"  }
         $2 ~ /^copilot/ { print $1, "copilot" }')

# в”Ђв”Ђ Build fzf entry list в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Each entry: "SESSION_NAME\tVISIBLE_LINE"
# fzf hides field 1 (--with-nth=2) and uses it for preview/action.

now=$(date +%s)
entries=()

while IFS=$'\t' read -r sess created; do
    # Determine agent + running status via awk lookup (bash 3.2 compat, no declare -A)
    match=$(printf '%s\n' "$active" | awk -v s="$sess" '$1 == s { print $2; exit }')

    if [[ -n "$match" ]]; then
        agent="$match"; running=true
    elif [[ "$sess" == *claude*  ]]; then agent="claude";  running=false
    elif [[ "$sess" == *copilot* ]]; then agent="copilot"; running=false
    else continue
    fi

    # Human-readable age
    age_s=$(( now - created ))
    if   (( age_s <    60 )); then age="${age_s}s"
    elif (( age_s <  3600 )); then age="$((age_s / 60))m"
    elif (( age_s < 86400 )); then age="$((age_s / 3600))h $((age_s % 3600 / 60))m"
    else                           age="$((age_s / 86400))d"
    fi

    if $running; then
        dot="${GREEN}в—Џ${RESET}"; state="${GREEN}Running${RESET}"
    else
        dot="${DIM}в—‹${RESET}";   state="${DIM}Idle   ${RESET}"
    fi

    visible=$(printf ' %s  %-12s  %s%-10s%s  %-28s  %s' \
        "$dot" "$state" "$PINK" "[$agent]" "$RESET" "$sess" "$age")
    entries+=( "${sess}"$'\t'"${visible}" )
done < <(
    tmux list-sessions -F '#{session_name}\t#{session_created}' 2>/dev/null \
        | sort -t$'\t' -k1,1
)

# в”Ђв”Ђ Separator + "new session" actions в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if (( ${#entries[@]} > 0 )); then
    entries+=( "__sep__"$'\t'"  ${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}" )
fi
entries+=( "__new_claude__"$'\t'"  ${DIM}+  new${RESET}  ${PINK}[claude] ${RESET} ${DIM}spawn a new claude session${RESET}" )
entries+=( "__new_copilot__"$'\t'"  ${DIM}+  new${RESET}  ${PINK}[copilot]${RESET} ${DIM}spawn a new copilot session${RESET}" )

# в”Ђв”Ђ fzf в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
header="$(printf '%s  %-12s  %-10s  %-28s  %s%s' \
    "${BOLD}${PINK} " "STATUS" "TYPE" "SESSION" "AGE" "${RESET}")"

selected=$(printf '%s\n' "${entries[@]}" | fzf \
    --ansi \
    --prompt="  agent monitor  " \
    $FZF_NAV \
    --no-info \
    --header="$header" \
    --delimiter=$'\t' \
    --with-nth=2 \
    --preview='
        sess={1}
        case "$sess" in
            __new_*|__sep__)
                echo "(select to spawn a new session)"
                ;;
            *)
                if tmux has-session -t "$sess" 2>/dev/null; then
                    tmux capture-pane -ep -t "$sess"
                else
                    echo "(session no longer exists)"
                fi
                ;;
        esac
    ' \
    --preview-window="right:50%:wrap") || exit 0

sess=$(printf '%s' "$selected" | cut -f1)
[[ -z "$sess" || "$sess" == "__sep__" ]] && exit 0

# в”Ђв”Ђ Action on selection в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
_new_session() {
    local prefix="$1" cmd="$2"
    local name="${prefix}-$(date +%H%M)"
    # Avoid name collision
    tmux has-session -t "$name" 2>/dev/null && name="${prefix}-$$"
    tmux new-session -d -s "$name"
    tmux send-keys -t "$name" "$cmd" Enter
    tmux switch-client -t "$name"
}

case "$sess" in
    __new_claude__)  _new_session "claude"  "claude"  ;;
    __new_copilot__) _new_session "copilot" "copilot" ;;
    *)
        if tmux has-session -t "$sess" 2>/dev/null; then
            tmux switch-client -t "$sess"
        else
            tmux display-message "Session '$sess' no longer exists"
        fi
        ;;
esac
