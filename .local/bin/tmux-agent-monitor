#!/usr/bin/env bash
# tmux-agent-monitor вЂ” K8s-style AI agent session manager
#
# Lists tmux sessions, marking which ones have an active Claude Code or
# Copilot agent running. Select to switch; pick "new" to spawn one.
# Navigate: ctrl-j/k, tab, enter, esc.
#
# Called via:  tmux display-popup -E 'tmux-agent-monitor'

FZF_NAV="--bind=ctrl-j:down,ctrl-k:up,ctrl-n:down,ctrl-p:up,ctrl-y:accept,tab:accept"

PINK=$'\e[38;2;197;142;167m'
GREEN=$'\e[38;2;180;250;158m'
CYAN=$'\e[38;2;148;247;228m'
DIM=$'\e[2m'
BOLD=$'\e[1m'
RESET=$'\e[0m'

# в”Ђв”Ђ Detect running agents в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Claude Code's pane_current_command is its version number (e.g. "2.1.179"),
# not the string "claude". Use pane_title (set by Claude Code to task
# descriptions like "вњі Claude Code") and the semver command pattern together.
# Copilot matches by command/title name.
active=$(tmux list-panes -a \
    -F '#{session_name}\t#{pane_current_command}\t#{pane_title}' 2>/dev/null | \
    awk -F'\t' '
        $2 ~ /^[0-9]+\.[0-9]+\.[0-9]+$/ { print $1, "claude"; next }
        $3 ~ /[Cc]laude/                 { print $1, "claude"; next }
        $2 ~ /^copilot/                  { print $1, "copilot"; next }
        $3 ~ /[Cc]opilot/               { print $1, "copilot"; next }
    ')

# в”Ђв”Ђ Build entry list в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Each entry: "SESSION_NAME\tVISIBLE_LINE"
# fzf hides field 1 (--with-nth=2) and uses it for preview/switching.

now=$(date +%s)
entries_running=()
entries_idle=()

while IFS=$'\t' read -r sess created; do
    match=$(printf '%s\n' "$active" | awk -v s="$sess" '$1 == s { print $2; exit }')

    age_s=$(( now - created ))
    if   (( age_s <    60 )); then age="${age_s}s"
    elif (( age_s <  3600 )); then age="$((age_s / 60))m"
    elif (( age_s < 86400 )); then age="$((age_s / 3600))h $((age_s % 3600 / 60))m"
    else                           age="$((age_s / 86400))d"
    fi

    if [[ -n "$match" ]]; then
        agent="$match"
        dot="${GREEN}в—Џ${RESET}"; state="${GREEN}Running${RESET}"
        visible=$(printf ' %s  %-12s  %s%-10s%s  %-30s  %s' \
            "$dot" "$state" "$PINK" "[$agent]" "$RESET" "$sess" "$age")
        entries_running+=( "${sess}"$'\t'"${visible}" )
    else
        dot="${DIM}в—‹${RESET}"; state="${DIM}Idle   ${RESET}"
        # Guess agent type from session name; otherwise show generic marker
        if   [[ "$sess" == *claude*  ]]; then badge="${PINK}[claude] ${RESET}"
        elif [[ "$sess" == *copilot* ]]; then badge="${PINK}[copilot]${RESET}"
        else                                  badge="${DIM}[-]      ${RESET}"
        fi
        visible=$(printf ' %s  %s%s  %s  %-30s  %s' \
            "$dot" "${DIM}" "Idle   " "$badge" "${RESET}${sess}" "$age")
        entries_idle+=( "${sess}"$'\t'"${visible}" )
    fi
done < <(
    tmux list-sessions -F '#{session_name}\t#{session_created}' 2>/dev/null \
        | sort -t$'\t' -k1,1
)

# в”Ђв”Ђ Assemble list: running first, then idle (with separator), then "new" в”Ђв”Ђ
entries=()
for e in "${entries_running[@]}"; do entries+=("$e"); done
if (( ${#entries_running[@]} > 0 && ${#entries_idle[@]} > 0 )); then
    entries+=( "__sep__"$'\t'"  ${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}" )
fi
for e in "${entries_idle[@]}"; do entries+=("$e"); done
if (( ${#entries[@]} > 0 )); then
    entries+=( "__sep2__"$'\t'"  ${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}" )
fi
entries+=( "__new_claude__"$'\t'"  ${DIM}+  new${RESET}  ${PINK}[claude] ${RESET} ${DIM}spawn a new claude session${RESET}" )
entries+=( "__new_copilot__"$'\t'"  ${DIM}+  new${RESET}  ${PINK}[copilot]${RESET} ${DIM}spawn a new copilot session${RESET}" )

# в”Ђв”Ђ fzf в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
header="$(printf '%s  %-12s  %-10s  %-30s  %s%s' \
    "${BOLD}${PINK} " "STATUS" "TYPE" "SESSION" "AGE" "${RESET}")"

selected=$(printf '%s\n' "${entries[@]}" | fzf \
    --ansi \
    --prompt="  agent monitor  " \
    $FZF_NAV \
    --no-info \
    --header="$header" \
    --delimiter=$'\t' \
    --with-nth=2 \
    --preview='
        sess={1}
        case "$sess" in
            __new_*|__sep__*)
                echo "(select to spawn a new session)"
                ;;
            *)
                if tmux has-session -t "$sess" 2>/dev/null; then
                    tmux capture-pane -ep -t "$sess"
                else
                    echo "(session no longer exists)"
                fi
                ;;
        esac
    ' \
    --preview-window="right:50%:wrap") || exit 0

sess=$(printf '%s' "$selected" | cut -f1)
[[ -z "$sess" || "$sess" == __sep__* ]] && exit 0

# в”Ђв”Ђ Action в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
_new_session() {
    local prefix="$1" cmd="$2"
    local name="${prefix}-$(date +%H%M)"
    tmux has-session -t "$name" 2>/dev/null && name="${prefix}-$$"
    tmux new-session -d -s "$name"
    tmux send-keys -t "$name" "$cmd" Enter
    tmux switch-client -t "$name"
}

case "$sess" in
    __new_claude__)  _new_session "claude"  "claude"  ;;
    __new_copilot__) _new_session "copilot" "copilot" ;;
    *)
        if tmux has-session -t "$sess" 2>/dev/null; then
            tmux switch-client -t "$sess"
        else
            tmux display-message "Session '$sess' no longer exists"
        fi
        ;;
esac
