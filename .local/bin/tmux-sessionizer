#!/usr/bin/env sh

# Shared fzf navigation contract — see docs/keybindings.md. Passed inline
# because this runs in a tmux popup that may not inherit FZF_DEFAULT_OPTS.
FZF_NAV="--bind=ctrl-j:down,ctrl-k:up,ctrl-n:down,ctrl-p:up,ctrl-y:accept,tab:accept"

# -p <dir> [<dir2> ...]: fzf-browse the immediate subdirs of all given parents
# (follows symlinks, e.g. ~/notes -> iCloud). Bare arg: use it as the exact
# target. No args: fzf over the default roots (~/git and home).
if [ "$1" = "-p" ]; then
    shift
    selected=$(find -L "$@" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | fzf $FZF_NAV)
elif [ "$#" -eq 1 ]; then
    selected=$1
else
    selected=$(find -L ~/git ~ ~/notes -mindepth 1 -maxdepth 1 -type d 2>/dev/null | fzf $FZF_NAV)
fi

if [ -z "$selected" ]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)

if [ -z "$TMUX" ] && [ -z "$tmux_running" ]; then
    tmux new-session -s "$selected_name" -c "$selected" -n "editor"
    tmux send-keys -t "$selected_name:editor" "nvim" Enter
    tmux new-window -t "$selected_name" -c "$selected" -n "shell"
    tmux select-window -t "$selected_name:editor"
    tmux attach-session -t "$selected_name"
    exit 0
fi

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected" -n "editor"
    tmux send-keys -t "$selected_name:editor" "nvim" Enter
    tmux new-window -t "$selected_name" -c "$selected" -n "shell"
    tmux select-window -t "$selected_name:editor"
fi

tmux switch-client -t "$selected_name:editor"
