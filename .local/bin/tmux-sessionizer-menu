#!/usr/bin/env bash
# Session-finder: reads ~/.config/tmux/sessionizer.toml, builds a native
# tmux display-menu from its entries, and opens tmux-sessionizer (fzf) for
# the selected category. Navigate the menu with arrow keys or letter shortcuts.
# Called from tmux via: bind f run-shell "~/.local/bin/tmux-sessionizer-menu"
#
# Entry types:
#   dirs  = ["~/git", ...]   → tmux-sessionizer directory picker
#   dirs  = ["*"]            → expands to all dirs defined across other entries
#   cmd   = "some-script"    → runs the script in a display-popup (arbitrary TUI)

# Prefer the user's custom config; fall back to the shipped default/example.
# Customize by copying the .example to sessionizer.toml (see its header).
XDG="${XDG_CONFIG_HOME:-$HOME/.config}"
CONF="$XDG/tmux/sessionizer.toml"
[[ -f "$CONF" ]] || CONF="$XDG/tmux/sessionizer.toml.example"

[[ ! -f "$CONF" ]] && { tmux display-message "No sessionizer config found ($CONF)"; exit 1; }

json=$(python3 -c "
import tomllib, json, sys
with open(sys.argv[1], 'rb') as f:
    print(json.dumps(tomllib.load(f)))
" "$CONF") || { tmux display-message "Failed to parse $CONF"; exit 1; }

# Collect every dir from non-wildcard, non-cmd entries (used to expand '*')
all_dirs=()
while IFS= read -r line; do
    all_dirs+=("$line")
done < <(jq -r '
    .entries[]
    | select(.cmd == null)
    | select(.dirs | map(. == "*") | any | not)
    | .dirs[]
' <<< "$json")

menu_args=()
seen_cmd=0

while IFS= read -r entry; do
    key=$(jq -r '.key'   <<< "$entry")
    label=$(jq -r '.label' <<< "$entry")

    # cmd entries: arbitrary TUI launched in a popup (e.g. tmux-agent-monitor)
    cmd_override=$(jq -r '.cmd // empty' <<< "$entry")
    if [[ -n "$cmd_override" ]]; then
        # visual separator before the first cmd entry
        (( seen_cmd )) || menu_args+=("")
        seen_cmd=1
        menu_args+=("${label}" "$key" "display-popup -E '${cmd_override}'")
        continue
    fi

    dirs=()
    while IFS= read -r d; do
        dirs+=("$d")
    done < <(jq -r '.dirs[]' <<< "$entry")

    if [[ "${dirs[0]}" == "*" ]]; then
        dirs=("${all_dirs[@]}")
    fi

    # Preview the dirs this entry browses, e.g. "git  (~/git, /mnt/c/git)".
    dir_str="${dirs[0]}"
    for d in "${dirs[@]:1}"; do dir_str+=", $d"; done

    # Build the -p args. Expand a leading ~ here (bash) because we single-quote
    # each dir below, which stops the sh that `display-popup -E` runs from doing
    # tilde expansion. Single-quoting lets paths with spaces or shell
    # metacharacters (e.g. the & in a OneDrive path) survive that sh intact.
    p_args="-p"
    for d in "${dirs[@]}"; do
        d="${d/#\~/$HOME}"
        p_args+=" '${d//\'/\'\\\'\'}'"
    done

    # Wrap the command in tmux DOUBLE quotes so the inner sh single quotes are
    # preserved when tmux re-parses this menu command on selection.
    menu_args+=("${label}  (${dir_str})" "$key" "display-popup -E \"tmux-sessionizer ${p_args}\"")
done < <(jq -c '.entries[]' <<< "$json")

exec tmux display-menu \
    -T "#[align=centre,fg=#C58EA7]󰍉 sessionizer " \
    -x C -y C \
    "${menu_args[@]}"
