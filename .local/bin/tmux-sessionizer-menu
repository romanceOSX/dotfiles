#!/usr/bin/env bash
# Session-finder: reads ~/.config/tmux/sessionizer.toml, builds a native
# tmux display-menu from its entries, and opens tmux-sessionizer (fzf) for
# the selected category. Navigate the menu with arrow keys or letter shortcuts.
# Called from tmux via: bind f run-shell "~/.local/bin/tmux-sessionizer-menu"

CONF="${XDG_CONFIG_HOME:-$HOME/.config}/tmux/sessionizer.toml"

[[ ! -f "$CONF" ]] && { tmux display-message "sessionizer.toml not found: $CONF"; exit 1; }

json=$(python3 -c "
import tomllib, json, sys
with open(sys.argv[1], 'rb') as f:
    print(json.dumps(tomllib.load(f)))
" "$CONF") || { tmux display-message "Failed to parse $CONF"; exit 1; }

# Collect every dir from non-wildcard entries (used to expand '*')
all_dirs=()
while IFS= read -r line; do
    all_dirs+=("$line")
done < <(jq -r '
    .entries[] | select(.dirs | map(. == "*") | any | not) | .dirs[]
' <<< "$json")

menu_args=()

while IFS= read -r entry; do
    label=$(jq -r '.label' <<< "$entry")

    dirs=()
    while IFS= read -r d; do
        dirs+=("$d")
    done < <(jq -r '.dirs[]' <<< "$entry")

    if [[ "${dirs[0]}" == "*" ]]; then
        dirs=("${all_dirs[@]}")
    fi

    p_args="-p"
    for d in "${dirs[@]}"; do p_args+=" $d"; done

    menu_args+=("${label}" "$key" "display-popup -E 'tmux-sessionizer ${p_args}'")
done < <(jq -c '.entries[]' <<< "$json")

exec tmux display-menu \
    -T "#[align=centre,fg=#C58EA7]󰍉 sessionizer " \
    -x C -y C \
    "${menu_args[@]}"
