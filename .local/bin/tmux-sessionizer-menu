#!/usr/bin/env bash
# Session-finder: reads ~/.config/tmux/sessionizer.toml, shows categories in
# an fzf picker, then browses the selected dirs with tmux-sessionizer.
# Called from tmux via: bind f run-shell "~/.local/bin/tmux-sessionizer-menu"

CONF="${XDG_CONFIG_HOME:-$HOME/.config}/tmux/sessionizer.toml"

[[ ! -f "$CONF" ]] && { tmux display-message "sessionizer.toml not found: $CONF"; exit 1; }

json=$(python3 -c "
import tomllib, json, sys
with open(sys.argv[1], 'rb') as f:
    print(json.dumps(tomllib.load(f)))
" "$CONF") || { tmux display-message "Failed to parse $CONF"; exit 1; }

# Collect every dir from non-wildcard entries (used to expand '*')
all_dirs=()
while IFS= read -r line; do
    all_dirs+=("$line")
done < <(jq -r '
    .entries[] | select(.dirs | map(. == "*") | any | not) | .dirs[]
' <<< "$json")

# Build a temp file of "label<TAB>-p dir1 dir2" lines — one per entry
tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT

while IFS= read -r entry; do
    label=$(jq -r '.label' <<< "$entry")

    dirs=()
    while IFS= read -r d; do
        dirs+=("$d")
    done < <(jq -r '.dirs[]' <<< "$entry")

    [[ "${dirs[0]}" == "*" ]] && dirs=("${all_dirs[@]}")

    p_args="-p"
    for d in "${dirs[@]}"; do p_args+=" $d"; done

    printf '%s\t%s\n' "$label" "$p_args" >> "$tmp"
done < <(jq -c '.entries[]' <<< "$json")

# Show categories in fzf (inside a popup so fzf has a tty), then hand off
# to tmux-sessionizer which runs a second fzf for dir/session picking.
# FZF_DEFAULT_OPTS is not set in this bash subprocess, so bind explicitly.
FZF_BIND="ctrl-j:down,ctrl-k:up,ctrl-n:down,ctrl-p:up,ctrl-y:accept,tab:accept"

tmux display-popup -E -w 40% -h 40% "bash -c '
    sel=\$(cut -f1 \"$tmp\" | fzf --prompt=\"󰍉  \" --bind=\"$FZF_BIND\" --no-info)
    [[ -z \"\$sel\" ]] && exit
    args=\$(grep -F \"\$sel\$(printf \"\\\t\")\" \"$tmp\" | head -1 | cut -f2-)
    exec tmux-sessionizer \$args
'"
