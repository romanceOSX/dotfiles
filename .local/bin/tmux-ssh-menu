#!/usr/bin/env bash
# tmux-ssh-menu вЂ” K8s-style SSH connection manager
#
# Lists configured + running SSH connections (status, session count), lets you
# open a new one by name/address, and on select re-enters the sessionizer dir
# picker over the REMOTE filesystem (see tmux-sessionizer -r).
#
# Reusable / standalone: run directly, or via tmux display-popup -E.
# Bound to <prefix>f s through the sessionizer TOML (cmd = "tmux-ssh-menu").

FZF_NAV="--bind=ctrl-j:down,ctrl-k:up,ctrl-n:down,ctrl-p:up,ctrl-y:accept,tab:accept"

# Shared SSH multiplexing opts вЂ” must match tmux-sessionizer so -O check sees
# the same control socket the panes use. %C keeps the path short on macOS.
SSH_SOCK_DIR="${XDG_RUNTIME_DIR:-$HOME/.ssh/sockets}"
mkdir -p "$SSH_SOCK_DIR" 2>/dev/null
SSH_OPTS="-o ControlMaster=auto -o ControlPath=$SSH_SOCK_DIR/%C -o ControlPersist=10m"

PINK=$'\e[38;2;197;142;167m'
AMBER=$'\e[38;2;246;207;148m'
GREEN=$'\e[38;2;180;250;158m'
DIM=$'\e[2m'
BOLD=$'\e[1m'
RESET=$'\e[0m'

XDG="${XDG_CONFIG_HOME:-$HOME/.config}"
CONF="$XDG/tmux/sessionizer.toml"
[[ -f "$CONF" ]] || CONF="$XDG/tmux/sessionizer.toml.example"

# Parse the TOML once to JSON (same pipeline as tmux-sessionizer-menu).
if [[ -f "$CONF" ]]; then
    JSON=$(python3 -c "
import tomllib, json, sys
with open(sys.argv[1], 'rb') as f:
    print(json.dumps(tomllib.load(f)))
" "$CONF" 2>/dev/null) || JSON='{}'
else
    JSON='{}'
fi

host_label() { jq -r --arg h "$1" '(.ssh // [])[] | select(.host==$h) | .label // empty' <<<"$JSON" | head -1; }
host_dirs()  { jq -r --arg h "$1" '(.ssh // [])[] | select(.host==$h) | (.dirs // [])[]' <<<"$JSON" | tr '\n' ' '; }

is_connected() { ssh $SSH_OPTS -O check "$1" >/dev/null 2>&1; }
session_count() {
    tmux list-sessions -F '#{@ssh_host}' 2>/dev/null | awk -v h="$1" 'NF && $0==h' | wc -l | tr -d ' '
}

# в”Ђв”Ђ Preview sub-mode: `tmux-ssh-menu --preview <host>` в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [[ "$1" == "--preview" ]]; then
    host="$2"
    case "$host" in
        __new__|__sep__*|"") echo "(select to open a new connection)"; exit 0 ;;
    esac
    printf '%sHOST%s   %s\n' "$BOLD" "$RESET" "$host"
    lbl=$(host_label "$host"); [[ -n "$lbl" ]] && printf '%slabel%s  %s\n' "$DIM" "$RESET" "$lbl"
    if is_connected "$host"; then
        printf '%sstate%s  %sConnected%s (control master live)\n' "$DIM" "$RESET" "$GREEN" "$RESET"
    else
        printf '%sstate%s  %sIdle%s\n' "$DIM" "$RESET" "$DIM" "$RESET"
    fi
    dirs=$(host_dirs "$host")
    printf '%sdirs%s   %s\n' "$DIM" "$RESET" "${dirs:-~ ~/git (default)}"
    echo
    echo "${DIM}sessions:${RESET}"
    tmux list-sessions -F '#{@ssh_host}#{?@ssh_host,	,}#{session_name}' 2>/dev/null \
        | awk -F'\t' -v h="$host" '$1==h { print "  вЂў " $2 }'
    exit 0
fi

# в”Ђв”Ђ Gather hosts: configured (TOML) в€Є tagged (running sessions) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
all_hosts=$(
    {
        jq -r '(.ssh // [])[].host' <<<"$JSON" 2>/dev/null
        tmux list-sessions -F '#{@ssh_host}' 2>/dev/null | awk 'NF'
    } | awk 'NF && !seen[$0]++'
)

entries_up=()
entries_idle=()
while IFS= read -r host; do
    [[ -z "$host" ]] && continue
    lbl=$(host_label "$host"); [[ -z "$lbl" ]] && lbl="$host"
    n=$(session_count "$host")
    if is_connected "$host"; then
        visible=$(printf ' %sв—Џ%s  %sConnected%s  %ssessions:%-3s%s  %s%-18s%s  %s' \
            "$GREEN" "$RESET" "$GREEN" "$RESET" "$DIM" "$n" "$RESET" "$PINK" "$lbl" "$RESET" "$host")
        entries_up+=( "${host}"$'\t'"${visible}" )
    else
        visible=$(printf ' %sв—‹  Idle       sessions:%-3s  %-18s  %s%s' \
            "$DIM" "$n" "$lbl" "$host" "$RESET")
        entries_idle+=( "${host}"$'\t'"${visible}" )
    fi
done < <(printf '%s\n' "$all_hosts")

entries=()
for e in "${entries_up[@]}";   do entries+=("$e"); done
for e in "${entries_idle[@]}"; do entries+=("$e"); done
if (( ${#entries[@]} > 0 )); then
    entries+=( "__sep__"$'\t'"  ${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}" )
fi
entries+=( "__new__"$'\t'"  ${AMBER}+  new connection${RESET}  ${DIM}connect to a host by name or address${RESET}" )

header="$(printf '%s  %-11s  %-12s  %-18s  %s%s' "${BOLD}${PINK} " "STATUS" "" "HOST" "TARGET" "$RESET")"

selected=$(printf '%s\n' "${entries[@]}" | fzf \
    --ansi \
    --prompt="  ssh connections  " \
    $FZF_NAV \
    --no-info \
    --header="$header" \
    --delimiter=$'\t' \
    --with-nth=2 \
    --preview="$0 --preview {1}" \
    --preview-window="right:45%:wrap") || exit 0

host=$(printf '%s' "$selected" | cut -f1)
[[ -z "$host" || "$host" == __sep__* ]] && exit 0

# в”Ђв”Ђ New connection: pick from known candidates or type a fresh host в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [[ "$host" == "__new__" ]]; then
    candidates=$(
        {
            jq -r '(.ssh // [])[].host' <<<"$JSON" 2>/dev/null
            # ~/.ssh/config Host aliases (skip wildcards)
            [[ -f "$HOME/.ssh/config" ]] && awk 'tolower($1)=="host"{for(i=2;i<=NF;i++) print $i}' \
                "$HOME/.ssh/config" | grep -v '[*?]'
            # known_hosts (strip [brackets]:port and comma lists)
            [[ -f "$HOME/.ssh/known_hosts" ]] && awk '{print $1}' "$HOME/.ssh/known_hosts" \
                | tr ',' '\n' | sed 's/^\[//; s/\]:.*$//'
        } | awk 'NF && !seen[$0]++'
    )
    pick=$(printf '%s\n' "$candidates" | fzf \
        --prompt="  ssh host  " \
        --print-query \
        $FZF_NAV \
        --header="type a hostname/IP or pick a known host")
    # --print-query prints the query on line 1, the selection (if any) on line 2.
    host=$(printf '%s\n' "$pick" | sed -n '2p')
    [[ -z "$host" ]] && host=$(printf '%s\n' "$pick" | sed -n '1p')
    [[ -z "$host" ]] && exit 0
fi

# Hand off to the sessionizer in remote mode (its TOML dirs, or its defaults).
dirs=$(host_dirs "$host")
# shellcheck disable=SC2086  # intentional word-splitting of the dir list
exec tmux-sessionizer -r "$host" $dirs
