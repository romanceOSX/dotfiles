#!/usr/bin/env bash
# tmux-ssh-menu — K8s-style SSH connection manager
#
# Lists configured + cached + running SSH connections (status, session count),
# lets you open a new one by name/address, and on select re-enters the
# sessionizer dir picker over the REMOTE filesystem (see tmux-sessionizer -r).
#
# Hosts come from three sources, unioned: the TOML [[ssh]] blocks ("configured",
# shared via git), a machine-local cache of hosts actually connected to from this
# box ("cached", written by tmux-sessionizer), and any currently-running remote
# sessions ("live"). Each row is tagged [cfg]/[seen] so a node pre-declared on
# another machine is distinguishable from one this machine has really reached.
#
# Reusable / standalone: run directly, or via tmux display-popup -E.
# Bound to <prefix>f s through the sessionizer TOML (cmd = "tmux-ssh-menu").

FZF_NAV="--bind=ctrl-j:down,ctrl-k:up,ctrl-n:down,ctrl-p:up,ctrl-y:accept,tab:accept"

# Shared SSH multiplexing opts — must match tmux-sessionizer so -O check sees
# the same control socket the panes use. %C keeps the path short on macOS.
SSH_SOCK_DIR="${XDG_RUNTIME_DIR:-$HOME/.ssh/sockets}"
mkdir -p "$SSH_SOCK_DIR" 2>/dev/null
SSH_OPTS="-o ControlMaster=auto -o ControlPath=$SSH_SOCK_DIR/%C -o ControlPersist=10m"

PINK=$'\e[38;2;197;142;167m'
AMBER=$'\e[38;2;246;207;148m'
GREEN=$'\e[38;2;180;250;158m'
DIM=$'\e[2m'
BOLD=$'\e[1m'
RESET=$'\e[0m'

XDG="${XDG_CONFIG_HOME:-$HOME/.config}"
CONF="$XDG/tmux/sessionizer.toml"
[[ -f "$CONF" ]] || CONF="$XDG/tmux/sessionizer.toml.example"

# Machine-local cache of hosts actually connected to from this box (written by
# tmux-sessionizer on a successful remote connect). Kept under XDG_STATE_HOME,
# OUTSIDE the dots repo, so it reflects THIS machine's reality rather than
# hosts that were pre-declared on some other machine and shared via the git TOML.
CACHE="${XDG_STATE_HOME:-$HOME/.local/state}/tmux/ssh-hosts"

# Parse the TOML once to JSON (same pipeline as tmux-sessionizer-menu).
if [[ -f "$CONF" ]]; then
    JSON=$(python3 -c "
import tomllib, json, sys
with open(sys.argv[1], 'rb') as f:
    print(json.dumps(tomllib.load(f)))
" "$CONF" 2>/dev/null) || JSON='{}'
else
    JSON='{}'
fi

host_label() { jq -r --arg h "$1" '(.ssh // [])[] | select(.host==$h) | .label // empty' <<<"$JSON" | head -1; }
host_dirs()  { jq -r --arg h "$1" '(.ssh // [])[] | select(.host==$h) | (.dirs // [])[]' <<<"$JSON" | tr '\n' ' '; }

# Where a host is known from: pre-declared in the TOML ("configured") and/or
# connected-to before from this machine ("cached"). A host can be both.
is_configured() { jq -e --arg h "$1" 'any((.ssh // [])[]; .host==$h)' <<<"$JSON" >/dev/null 2>&1; }
is_cached()     { [[ -f "$CACHE" ]] && grep -qxF "$1" "$CACHE"; }
# Compact, dim provenance tag shown at the end of each row, e.g. [cfg·seen].
# A bare [cfg] host was declared (maybe on another machine) but never reached
# here; [seen] means this box has actually connected to it.
src_tag() {
    local t=""
    is_configured "$1" && t="cfg"
    is_cached "$1"     && t="${t:+$t·}seen"
    [[ -n "$t" ]] && printf '%s[%s]%s' "$DIM" "$t" "$RESET"
}

is_connected() { ssh $SSH_OPTS -O check "$1" >/dev/null 2>&1; }
session_count() {
    tmux list-sessions -F '#{@ssh_host}' 2>/dev/null | awk -v h="$1" 'NF && $0==h' | wc -l | tr -d ' '
}

# ── Preview sub-mode: `tmux-ssh-menu --preview <host>` ─────────────────────
if [[ "$1" == "--preview" ]]; then
    host="$2"
    case "$host" in
        __new__|__sep__*|"") echo "(select to open a new connection)"; exit 0 ;;
    esac
    printf '%sHOST%s   %s\n' "$BOLD" "$RESET" "$host"
    lbl=$(host_label "$host"); [[ -n "$lbl" ]] && printf '%slabel%s  %s\n' "$DIM" "$RESET" "$lbl"
    # Provenance: configured (declared in the TOML, possibly on another machine)
    # and/or cached (this machine has connected to it before).
    srcs=()
    is_configured "$host" && srcs+=("configured")
    is_cached "$host"     && srcs+=("cached")
    [[ ${#srcs[@]} -eq 0 ]] && srcs+=("ad-hoc")
    printf '%ssource%s %s\n' "$DIM" "$RESET" "$(IFS=', '; echo "${srcs[*]}")"
    if is_connected "$host"; then
        printf '%sstate%s  %sConnected%s (control master live)\n' "$DIM" "$RESET" "$GREEN" "$RESET"
    else
        printf '%sstate%s  %sIdle%s\n' "$DIM" "$RESET" "$DIM" "$RESET"
    fi
    dirs=$(host_dirs "$host")
    printf '%sdirs%s   %s\n' "$DIM" "$RESET" "${dirs:-~ ~/git (default)}"
    echo
    echo "${DIM}sessions:${RESET}"
    tmux list-sessions -F '#{@ssh_host}#{?@ssh_host,	,}#{session_name}' 2>/dev/null \
        | awk -F'\t' -v h="$host" '$1==h { print "  • " $2 }'
    exit 0
fi

# ── Gather hosts: configured (TOML) ∪ cached (connected before) ∪ live ─────
all_hosts=$(
    {
        jq -r '(.ssh // [])[].host' <<<"$JSON" 2>/dev/null
        [[ -f "$CACHE" ]] && grep -v '^[[:space:]]*$' "$CACHE"
        tmux list-sessions -F '#{@ssh_host}' 2>/dev/null | awk 'NF'
    } | awk 'NF && !seen[$0]++'
)

entries_up=()
entries_idle=()
while IFS= read -r host; do
    [[ -z "$host" ]] && continue
    lbl=$(host_label "$host"); [[ -z "$lbl" ]] && lbl="$host"
    n=$(session_count "$host")
    tag=$(src_tag "$host")
    if is_connected "$host"; then
        visible=$(printf ' %s●%s  %sConnected%s  %ssessions:%-3s%s  %s%-18s%s  %s  %s' \
            "$GREEN" "$RESET" "$GREEN" "$RESET" "$DIM" "$n" "$RESET" "$PINK" "$lbl" "$RESET" "$host" "$tag")
        entries_up+=( "${host}"$'\t'"${visible}" )
    else
        visible=$(printf ' %s○  Idle       sessions:%-3s  %-18s  %s%s  %s' \
            "$DIM" "$n" "$lbl" "$host" "$RESET" "$tag")
        entries_idle+=( "${host}"$'\t'"${visible}" )
    fi
done < <(printf '%s\n' "$all_hosts")

entries=()
for e in "${entries_up[@]}";   do entries+=("$e"); done
for e in "${entries_idle[@]}"; do entries+=("$e"); done
if (( ${#entries[@]} > 0 )); then
    entries+=( "__sep__"$'\t'"  ${DIM}──────────────────────────────────────────────────${RESET}" )
fi
entries+=( "__new__"$'\t'"  ${AMBER}+  new connection${RESET}  ${DIM}connect to a host by name or address${RESET}" )

header="$(printf '%s  %-11s  %-12s  %-18s  %s%s' "${BOLD}${PINK} " "STATUS" "" "HOST" "TARGET" "$RESET")"

selected=$(printf '%s\n' "${entries[@]}" | fzf \
    --ansi \
    --prompt="  ssh connections  " \
    $FZF_NAV \
    --no-info \
    --header="$header" \
    --delimiter=$'\t' \
    --with-nth=2 \
    --preview="$0 --preview {1}" \
    --preview-window="right:45%:wrap") || exit 0

host=$(printf '%s' "$selected" | cut -f1)
[[ -z "$host" || "$host" == __sep__* ]] && exit 0

# ── New connection: pick from known candidates or type a fresh host ────────
if [[ "$host" == "__new__" ]]; then
    candidates=$(
        {
            jq -r '(.ssh // [])[].host' <<<"$JSON" 2>/dev/null
            # Hosts we've connected to before from this machine.
            [[ -f "$CACHE" ]] && grep -v '^[[:space:]]*$' "$CACHE"
            # ~/.ssh/config Host aliases (skip wildcards)
            [[ -f "$HOME/.ssh/config" ]] && awk 'tolower($1)=="host"{for(i=2;i<=NF;i++) print $i}' \
                "$HOME/.ssh/config" | grep -v '[*?]'
            # known_hosts (strip [brackets]:port and comma lists)
            [[ -f "$HOME/.ssh/known_hosts" ]] && awk '{print $1}' "$HOME/.ssh/known_hosts" \
                | tr ',' '\n' | sed 's/^\[//; s/\]:.*$//'
        } | awk 'NF && !seen[$0]++'
    )
    pick=$(printf '%s\n' "$candidates" | fzf \
        --prompt="  ssh host  " \
        --print-query \
        $FZF_NAV \
        --header="type a hostname/IP or pick a known host")
    # --print-query prints the query on line 1, the selection (if any) on line 2.
    host=$(printf '%s\n' "$pick" | sed -n '2p')
    [[ -z "$host" ]] && host=$(printf '%s\n' "$pick" | sed -n '1p')
    [[ -z "$host" ]] && exit 0
fi

# Hand off to the sessionizer in remote mode (its TOML dirs, or its defaults).
dirs=$(host_dirs "$host")
# shellcheck disable=SC2086  # intentional word-splitting of the dir list
exec tmux-sessionizer -r "$host" $dirs
