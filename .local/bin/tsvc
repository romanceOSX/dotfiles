#!/usr/bin/env bash
# tsvc — expose a docker service on the tailnet under its own MagicDNS name.
#
# Each service runs as a 2-container docker compose stack on this host's system
# dockerd: a `tailscale/tailscale` sidecar that joins the tailnet as a device
# named after the service and runs `tailscale serve` to front the app on HTTPS
# 443 (valid *.ts.net cert, no external domain), plus the app container sharing
# the sidecar's network namespace. So `tsvc up portainer` →
#   https://portainer.<tailnet>.ts.net
#
# Installed only on Linux `server` hosts (see home/tsvc.nix). Requires: dockerd
# reachable; the `tailscale/tailscale` image pullable; a Tailscale OAuth client
# secret rendered by sops (home/secrets.nix) with a `tag:svc` tag defined and
# HTTPS certificates enabled on the tailnet (admin console → DNS).
#
#   tsvc list                  # known service defs + running state
#   tsvc up   <svc>            # bring a service up  → prints its URL
#   tsvc down <svc> [--wipe]   # stop it (--wipe also drops its volumes)
#   tsvc status [svc]          # compose + tailnet device view
#   tsvc logs <svc> [app|ts]   # follow logs (default: app)
#   tsvc new  <svc> --image IMG --port N [--data VOL[:PATH]] [--mount H:C] [--ephemeral]
#
# Service defs live in ~/.config/tsvc/services/<svc>.env. The checked-in ones
# (portainer/paisa/meddy) are managed by nix; `tsvc new` scaffolds ad-hoc ones
# in the same dir. A def sets SVC_IMAGE + SVC_PORT and optionally:
#   SVC_DATA_VOLUME / SVC_DATA_PATH   named volume for the app's data
#   SVC_MOUNTS                        extra binds, space-separated host:container
#   SVC_CMD                           args appended to the image entrypoint
#   SVC_PROXY_HOST                    sidecar-only: proxy to this host:SVC_PORT
#                                     (e.g. a dev build on the host) instead of an
#                                     app container. No app container is rendered,
#                                     so SVC_IMAGE is unused. The route/cert stay
#                                     live; requests 502 until something listens.
#   SVC_PULL                          compose pull policy (missing|always|never)
#   EPHEMERAL                         true → node auto-deregisters on `down`
#   TS_IMAGE_TAG                      tailscale sidecar image tag (default latest)
set -euo pipefail

# Find the nix-profile tools (tailscale/docker/jq) even from a non-login shell.
export PATH="$HOME/.nix-profile/bin:/nix/var/nix/profiles/default/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tsvc"
SVC_DIR="$CONF_DIR/services"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/tsvc"
CONFIG_ENV="$CONF_DIR/config.env"

die() { echo "tsvc: $*" >&2; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || die "$1 not found on PATH."; }

# nix-managed runtime config: TS_AUTHKEY_FILE (sops path) + TS_TAG.
TS_TAG="tag:svc"
TS_AUTHKEY_FILE=""
# shellcheck disable=SC1090
[ -r "$CONFIG_ENV" ] && . "$CONFIG_ENV"

check_docker() {
  need docker
  docker info >/dev/null 2>&1 || die "docker daemon not reachable — is dockerd running? (sudo systemctl status docker)"
  docker compose version >/dev/null 2>&1 || die "the docker compose v2 plugin is not available."
}

read_authkey() {
  [ -n "$TS_AUTHKEY_FILE" ] || die "TS_AUTHKEY_FILE unset — is $CONFIG_ENV present? (run hm-switch)"
  [ -r "$TS_AUTHKEY_FILE" ] || die "can't read the Tailscale OAuth secret at $TS_AUTHKEY_FILE — has sops rendered it? (systemctl --user status sops-nix.service)"
  TS_AUTHKEY="$(cat "$TS_AUTHKEY_FILE")"
  [ -n "$TS_AUTHKEY" ] || die "the Tailscale OAuth secret at $TS_AUTHKEY_FILE is empty."
}

load_def() {
  local svc="$1" f
  f="$SVC_DIR/$svc.env"
  [ -r "$f" ] || die "no service def for '$svc' ($f). Add one, or: tsvc new $svc --image … --port …"
  SVC_IMAGE="" SVC_PORT="" SVC_DATA_VOLUME="" SVC_DATA_PATH="/data" \
    SVC_MOUNTS="" SVC_CMD="" SVC_PROXY_HOST="" SVC_PULL="missing" \
    EPHEMERAL="false" TS_IMAGE_TAG="latest"
  # shellcheck disable=SC1090
  . "$f"
  [ -n "$SVC_PORT" ]  || die "$f: SVC_PORT is unset."
  # SVC_PROXY_HOST set → sidecar-only, proxy to an external host:port (a build
  # running on the host); no app container, so SVC_IMAGE isn't required.
  [ -n "$SVC_PROXY_HOST" ] || [ -n "$SVC_IMAGE" ] || die "$f: SVC_IMAGE is unset."
  SVC="$svc"
}

suffix() { tailscale status --json 2>/dev/null | jq -r '.MagicDNSSuffix // empty' 2>/dev/null || true; }

compose_file() { echo "$STATE_DIR/$1/docker-compose.yaml"; }

# Render the compose stack + serve.json for the loaded def into its rundir.
render() {
  local rundir="$STATE_DIR/$SVC"
  mkdir -p "$rundir"
  chmod 700 "$STATE_DIR" "$rundir" 2>/dev/null || true

  # serve.json — ${TS_CERT_DOMAIN} is expanded by the tailscale image to this
  # sidecar's own FQDN (<svc>.<tailnet>.ts.net); no need to hardcode the suffix.
  # Proxy target is the shared netns (app container) unless SVC_PROXY_HOST points
  # serve at an external host (a build on the docker host, reached via host-gateway).
  local proxy_target="127.0.0.1:$SVC_PORT"
  [ -n "$SVC_PROXY_HOST" ] && proxy_target="$SVC_PROXY_HOST:$SVC_PORT"
  cat > "$rundir/serve.json" <<JSON
{
  "TCP": { "443": { "HTTPS": true } },
  "Web": {
    "\${TS_CERT_DOMAIN}:443": {
      "Handlers": { "/": { "Proxy": "http://$proxy_target" } }
    }
  }
}
JSON

  local f="$rundir/docker-compose.yaml"
  {
    echo "# Generated by tsvc — do not edit; re-run 'tsvc up $SVC'."
    echo "name: tsvc-$SVC"
    echo "services:"
    echo "  tailscale:"
    echo "    image: tailscale/tailscale:$TS_IMAGE_TAG"
    echo "    hostname: $SVC"
    echo "    environment:"
    echo "      TS_AUTHKEY: \"\${TS_AUTHKEY:?}\""
    if [ "$EPHEMERAL" = "true" ]; then
      echo "      TS_EXTRA_ARGS: \"--advertise-tags=$TS_TAG --ephemeral\""
      echo "      TS_STATE_DIR: mem:"          # no on-disk identity for throwaway nodes
    else
      echo "      TS_EXTRA_ARGS: \"--advertise-tags=$TS_TAG\""
      echo "      TS_STATE_DIR: /var/lib/tailscale"
    fi
    echo "      TS_SERVE_CONFIG: /config/serve.json"
    echo "      TS_USERSPACE: \"true\""
    if [ -n "$SVC_PROXY_HOST" ]; then
      # let the userspace sidecar reach a build listening on the docker host
      echo "    extra_hosts:"
      echo "      - \"host.docker.internal:host-gateway\""
    fi
    echo "    volumes:"
    [ "$EPHEMERAL" = "true" ] || echo "      - tsvc-$SVC-state:/var/lib/tailscale"
    echo "      - $rundir/serve.json:/config/serve.json:ro"
    echo "    restart: unless-stopped"
    # No app container in sidecar-only (SVC_PROXY_HOST) mode — serve points at a
    # build on the host instead; the sidecar keeps the route/cert standing.
    if [ -z "$SVC_PROXY_HOST" ]; then
      echo "  app:"
      echo "    image: $SVC_IMAGE"
      echo "    network_mode: \"service:tailscale\""
      echo "    restart: unless-stopped"
      if [ -n "$SVC_CMD" ]; then
        # args appended to the image entrypoint, emitted as a YAML/JSON list so
        # each token stays a distinct arg regardless of spacing.
        local cmd_json="" w
        for w in $SVC_CMD; do cmd_json+="${cmd_json:+, }\"$w\""; done
        echo "    command: [$cmd_json]"
      fi
      if [ -n "$SVC_DATA_VOLUME" ] || [ -n "$SVC_MOUNTS" ]; then
        echo "    volumes:"
        [ -n "$SVC_DATA_VOLUME" ] && echo "      - $SVC_DATA_VOLUME:$SVC_DATA_PATH"
        local m
        for m in $SVC_MOUNTS; do echo "      - $m"; done
      fi
    fi
    if [ "$EPHEMERAL" != "true" ] || [ -n "$SVC_DATA_VOLUME" ]; then
      echo "volumes:"
      [ "$EPHEMERAL" = "true" ] || echo "  tsvc-$SVC-state:"
      [ -n "$SVC_DATA_VOLUME" ] && echo "  $SVC_DATA_VOLUME:"
    fi
  } > "$f"
  RUNDIR="$rundir"
}

cmd_up() {
  local svc="${1:-}"; [ -n "$svc" ] || die "usage: tsvc up <svc>"
  check_docker; load_def "$svc"; read_authkey; render
  echo "tsvc: starting $svc (device '$svc', $TS_TAG${EPHEMERAL:+, ephemeral=$EPHEMERAL})…" >&2
  TS_AUTHKEY="$TS_AUTHKEY" docker compose -f "$RUNDIR/docker-compose.yaml" up -d --pull "$SVC_PULL"
  local sfx; sfx="$(suffix)"
  if [ -n "$sfx" ]; then
    echo "tsvc: $svc → https://$svc.$sfx  (cert provisions on first request, ~30s)" >&2
  else
    echo "tsvc: $svc up — check 'tailscale status' for its device name." >&2
  fi
}

cmd_down() {
  local svc="${1:-}"; [ -n "$svc" ] || die "usage: tsvc down <svc> [--wipe]"
  local wipe=""; [ "${2:-}" = "--wipe" ] && wipe="--volumes"
  local f; f="$(compose_file "$svc")"
  [ -f "$f" ] || die "no rundir for '$svc' — was it ever brought up here?"
  check_docker
  docker compose -f "$f" down ${wipe:+$wipe}
  echo "tsvc: $svc stopped${wipe:+ (volumes wiped)}." >&2
}

cmd_logs() {
  local svc="${1:-}" which="${2:-app}"
  [ -n "$svc" ] || die "usage: tsvc logs <svc> [app|ts]"
  case "$which" in
    app) ;;
    ts|tailscale) which=tailscale ;;
    *) die "logs target must be 'app' or 'ts'." ;;
  esac
  local f; f="$(compose_file "$svc")"
  [ -f "$f" ] || die "not up: $svc"
  check_docker
  docker compose -f "$f" logs -f "$which"
}

cmd_list() {
  [ -d "$SVC_DIR" ] || die "no service defs dir ($SVC_DIR)."
  local running=""
  command -v docker >/dev/null 2>&1 && running="$(docker compose ls --all 2>/dev/null || true)"
  echo "service defs ($SVC_DIR):"
  local f svc state
  shopt -s nullglob
  for f in "$SVC_DIR"/*.env; do
    svc="$(basename "$f" .env)"
    state="not started"
    printf '%s' "$running" | grep -q "tsvc-$svc " && state="$(printf '%s' "$running" | awk -v p="tsvc-$svc" '$1==p{print $2}')"
    printf '  %-16s %s\n' "$svc" "$state"
  done
  shopt -u nullglob
}

cmd_status() {
  local only="${1:-}"
  need docker
  echo "== tsvc compose projects =="
  docker compose ls --all 2>/dev/null | grep -E 'NAME|tsvc-' || echo "(none running)"
  echo
  echo "== service URLs =="
  local sfx; sfx="$(suffix)"; [ -n "$sfx" ] || sfx="<tailnet>.ts.net"
  local f svc
  shopt -s nullglob
  for f in "$SVC_DIR"/*.env; do
    svc="$(basename "$f" .env)"
    [ -n "$only" ] && [ "$svc" != "$only" ] && continue
    printf '  %-16s https://%s.%s\n' "$svc" "$svc" "$sfx"
  done
  shopt -u nullglob
  echo
  echo "== tailnet devices =="
  tailscale status 2>/dev/null || echo "(tailscale status unavailable)"
}

cmd_new() {
  local svc="${1:-}"; [ -n "$svc" ] || die "usage: tsvc new <svc> --image IMG --port N [--data VOL[:PATH]] [--mount H:C] [--ephemeral]"
  shift
  local image="" port="" data="" mounts="" ephemeral="false"
  while [ $# -gt 0 ]; do
    case "$1" in
      --image) image="${2:?}"; shift 2 ;;
      --port)  port="${2:?}"; shift 2 ;;
      --data)  data="${2:?}"; shift 2 ;;
      --mount) mounts="$mounts ${2:?}"; shift 2 ;;
      --ephemeral) ephemeral="true"; shift ;;
      *) die "unknown arg: $1" ;;
    esac
  done
  [ -n "$image" ] && [ -n "$port" ] || die "new needs --image and --port."
  mkdir -p "$SVC_DIR"
  local f="$SVC_DIR/$svc.env"
  [ -e "$f" ] && die "$f already exists."
  {
    echo "# tsvc service def (ad-hoc). Permanent services live in the dots repo"
    echo "# under home/tsvc/services/ and are installed by nix."
    echo "SVC_IMAGE=$image"
    echo "SVC_PORT=$port"
    if [ -n "$data" ]; then
      echo "SVC_DATA_VOLUME=${data%%:*}"
      case "$data" in *:*) echo "SVC_DATA_PATH=${data#*:}" ;; esac
    fi
    [ -n "$mounts" ] && echo "SVC_MOUNTS=\"${mounts# }\""
    echo "EPHEMERAL=$ephemeral"
  } > "$f"
  echo "tsvc: wrote $f — 'tsvc up $svc' to start." >&2
}

main() {
  local cmd="${1:-list}"; shift || true
  case "$cmd" in
    up)     cmd_up "$@" ;;
    down)   cmd_down "$@" ;;
    logs)   cmd_logs "$@" ;;
    status) cmd_status "$@" ;;
    list|ls) cmd_list "$@" ;;
    new)    cmd_new "$@" ;;
    -h|--help|help) sed -n '2,32p' "$0" | sed 's/^# \{0,1\}//' ;;
    *) die "unknown command '$cmd' (try: up down status logs list new)" ;;
  esac
}

main "$@"
