#!/usr/bin/env sh

# Sync WSL's /etc/resolv.conf with the Windows host's *current* DNS servers.
#
# WSL2's NAT DNS proxy (the gateway IP) is often blocked by host/corporate
# firewalls, so `generateResolvConf=false` is set and resolv.conf is managed by
# hand. Hardcoding public resolvers (8.8.8.8/1.1.1.1) breaks on networks that
# block outbound DNS (e.g. a corporate VPN), which makes name resolution — and
# anything depending on it, like `tailscale up` — hang.
#
# This pulls the real DNS servers Windows is using right now (Wi-Fi / Ethernet /
# VPN adapters) and writes them into resolv.conf, so DNS follows you across
# networks. Re-run it whenever you switch networks or connect/disconnect a VPN.
#
# Requires sudo (to write /etc/resolv.conf). WSL only.

set -e

if ! grep -qi microsoft /proc/version 2>/dev/null; then
    echo "error: this only applies to WSL." >&2
    exit 1
fi

if ! command -v powershell.exe >/dev/null 2>&1; then
    echo "error: powershell.exe not found on PATH (is interop enabled?)." >&2
    exit 1
fi

# Query the Windows host for IPv4 DNS servers, skipping the loopback and the
# WSL virtual adapter (whose 'DNS' is the unreachable NAT proxy).
servers=$(powershell.exe -NoProfile -Command \
    "(Get-DnsClientServerAddress -AddressFamily IPv4 | Where-Object { \$_.ServerAddresses -and \$_.InterfaceAlias -notmatch 'Loopback|vEthernet' }).ServerAddresses" \
    2>/dev/null | tr -d '\r' | sed '/^$/d' | awk '!seen[$0]++')

if [ -z "$servers" ]; then
    echo "error: could not read any DNS servers from the Windows host." >&2
    exit 1
fi

tmp=$(mktemp)
{
    echo "# Generated by wsl-sync-dns from the Windows host's DNS settings."
    echo "# Re-run 'wsl-sync-dns' after changing networks or VPN state."
    for s in $servers; do
        echo "nameserver $s"
    done
} > "$tmp"

sudo cp "$tmp" /etc/resolv.conf
rm -f "$tmp"

echo "Updated /etc/resolv.conf with:"
for s in $servers; do
    echo "  nameserver $s"
done
