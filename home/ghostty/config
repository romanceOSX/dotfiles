# ghostty — pastel rainbow theme with 90% opacity transparent background.
# Source of truth; symlinked to ~/.config/ghostty/config via home/programs.nix.

# --- Font (SFMono Nerd Font Complete, 14pt) ---
font-family = SFMono Nerd Font
font-size = 14

# --- Window / transparency ---
# No background-blur: it noticeably increases GPU/battery draw.
background-opacity = 0.90

# --- SSH terminfo handshake (Ghostty 1.2.0+) ---
# ssh-terminfo: auto-install the xterm-ghostty entry on remote hosts that lack
# it (the long tail of unmanaged/embedded boxes), so ^L/clear doesn't corrupt
# the display. ssh-env: graceful TERM fallback where it can't install (read-only
# rootfs, busybox, no tic). HM-managed hosts already ship the entry in
# ~/.terminfo (see home/programs.nix), so this just covers everything else.
shell-integration-features = ssh-env,ssh-terminfo

# --- Base colors ---
# Darker base so pastels pop more
background = 1a1a26
foreground = e8e6f0
cursor-color = ffb3d9
cursor-text = 1a1a26
selection-background = 5a4a6a
selection-foreground = f5f3ff

# --- Pastel rainbow palette (16 colors) ---
# Normal
palette = 0=3a3548
palette = 1=ffb3ba
palette = 2=baffc9
palette = 3=ffffba
palette = 4=bae1ff
palette = 5=e0baff
palette = 6=baf7ff
