# tmux-sessionizer directory configuration (DEFAULT / EXAMPLE)
# ────────────────────────────────────────────────────────────
# This is the shipped default, deployed read-only to
#   ~/.config/tmux/sessionizer.toml.example
# The <prefix>f menu uses it ONLY when no custom config exists.
#
# To customize, copy it to a writable config the menu prefers:
#   cp ~/.config/tmux/sessionizer.toml.example ~/.config/tmux/sessionizer.toml
# then edit that copy. It is read fresh at every <prefix>f keypress, so
# changes take effect immediately — no home-manager switch, no tmux reload.
# (Your copy lives outside the dotfiles repo, like local.nix — machine-local.)
#
# Each [[entries]] block maps a menu key to one or more root directories,
# or to an arbitrary command TUI.
#
#   key   — single character used in the <prefix>f session-finder menu
#   label — display name shown in the menu
#   dirs  — one or more parent directories to browse (tilde is supported)
#   cmd   — instead of dirs: a script/command launched in a tmux display-popup
#
# Use dirs=["*"] to create a "search all" entry that expands to every
# directory defined in every other entry. The key and label are configurable.
#
# SSH remotes live in separate [[ssh]] blocks (read by tmux-ssh-menu, reached
# via the "ssh" cmd entry below / <prefix>f s):
#
#   host  — ssh target: a ~/.ssh/config alias, hostname, or IP
#   label — optional display name in the connections menu (defaults to host)
#   dirs  — remote directories to browse; the REMOTE shell expands ~
#
# Selecting a remote opens a local tmux session whose panes ssh into the host
# at the chosen dir; the session is tinted amber and named "<host>·<dir>".

[[entries]]
key   = "g"
label = "git"
dirs  = ["~/git", "/mnt/c/git"]

[[entries]]
key   = "n"
label = "notes"
dirs  = ["/mnt/c/Users/b5s5k7t/OneDrive-Deere&Co/OneDrive - Deere & Co/Documents/notes/"]

[[entries]]
key   = "h"
label = "home"
dirs  = ["~"]

[[entries]]
key   = "f"
label = "all"
dirs  = ["*"]

# cmd entries — arbitrary TUI scripts (appear below a separator in the menu)
[[entries]]
key   = "a"
label = "agents"
cmd   = "tmux-agent-monitor"

[[entries]]
key   = "s"
label = "ssh"
cmd   = "tmux-ssh-menu"

# ── SSH remotes (consumed by tmux-ssh-menu / <prefix>f s) ──────────────────
[[ssh]]
host  = "alien"
label = "alienware · heavy processing"
dirs  = ["~", "~/git"]

[[ssh]]
host  = "pi"
label = "raspberry pi"
dirs  = ["~", "~/git"]
