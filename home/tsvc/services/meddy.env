# meddy — dev project, brought up only during dev runs → https://meddy.<tailnet>.ts.net
#
# Ephemeral tailnet node: the device appears while the stack is up and auto-
# deregisters on `tsvc down meddy`, so it never lingers in the tailnet between
# runs. Point it at your dev image/port at run time (defaults below):
#
#   MEDDY_IMAGE=meddy:dev MEDDY_PORT=3000 tsvc up meddy
#
# SVC_PULL=never because the dev image is built locally, not pulled from a registry.
SVC_IMAGE=${MEDDY_IMAGE:-meddy:dev}
SVC_PORT=${MEDDY_PORT:-3000}
SVC_PULL=never
EPHEMERAL=true
