# Paisa — personal finance / ledger web UI → https://paisa.<tailnet>.ts.net
#
# Official image (Docker Hub). It serves on :7500 inside the sidecar's netns;
# Tailscale terminates TLS with a valid *.ts.net cert. Paisa reads its config
# (paisa.yaml) and journal from ~/Documents/paisa in-container, so we bind the
# host's finance folder there. $HOME/finance is where the ledger lives; it also
# holds paisa's sqlite db (paisa.db), so the mount must be writable.
#
# hledger/beancount users: swap :latest for a backend variant tag, e.g.
#   ananthakumaran/paisa:latest-hledger  |  :latest-beancount  |  :latest-all
SVC_IMAGE=ananthakumaran/paisa:latest
SVC_PORT=7500
SVC_MOUNTS="${HOME}/finance:/root/Documents/paisa"
SVC_PULL=always
EPHEMERAL=false
