# Paisa — personal finance / ledger web UI → https://paisa.<tailnet>.ts.net
#
# Official image (Docker Hub). It serves on :7500 inside the sidecar's netns;
# Tailscale terminates TLS with a valid *.ts.net cert. Paisa reads its config
# (paisa.yaml) and journal from ~/Documents/paisa in-container, so we bind the
# host's finance folder there. $HOME/finance is where the ledger lives; it also
# holds paisa's sqlite db (paisa.db), so the mount must be writable.
#
# Uses the -hledger backend variant: main.journal is hledger-flavored (periodic
# transactions with inline descriptions), which the default `ledger` CLI can't
# parse. paisa.yaml must set `ledger_cli: hledger` to match. Other backends:
#   ananthakumaran/paisa:latest  (ledger)  |  :latest-beancount  |  :latest-all
SVC_IMAGE=ananthakumaran/paisa:latest-hledger
SVC_PORT=7500
SVC_MOUNTS="${HOME}/finance:/root/Documents/paisa"
# Also publish :7500 to the host loopback so this host's system-wide nginx
# (home/system-proxy.nix) can front it at paisa.${INTERNAL_DOMAIN}, alongside
# the tailnet-only URL above. Loopback-only — never exposed beyond this host.
# Same pattern as portainer.env.
SVC_PUBLISH_HOST=127.0.0.1
SVC_PULL=always
EPHEMERAL=false
