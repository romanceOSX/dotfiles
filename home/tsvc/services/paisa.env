# Paisa — personal finance / double-entry ledger web UI
# (github.com/ananthakumaran/paisa) → https://paisa.<tailnet>.ts.net
#
# CONFIRM before first use: the upstream image serves on 7500 and reads its
# journal + paisa.yaml from the working dir. Adjust SVC_IMAGE / SVC_PORT /
# SVC_DATA_PATH to match how you run paisa, then `tsvc up paisa`.
SVC_IMAGE=ghcr.io/ananthakumaran/paisa:latest
SVC_PORT=7500
SVC_DATA_VOLUME=paisa_data
SVC_DATA_PATH=/data
SVC_PULL=always
EPHEMERAL=false
