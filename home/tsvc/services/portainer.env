# Portainer CE — docker management web UI → https://portainer.<tailnet>.ts.net
#
# The app runs on plain HTTP :9000 inside the sidecar's network namespace;
# Tailscale terminates TLS with a valid *.ts.net cert. It manages this host's
# dockerd, so it needs the docker socket bind-mounted.
#
# This is the MagicDNS-routed Portainer. The standalone `portainer` launcher
# (home/portainer.nix) still exists for a quick localhost-only container; don't
# run both at once — they share the portainer_data volume.
SVC_IMAGE=portainer/portainer-ce:latest
SVC_PORT=9000
SVC_DATA_VOLUME=portainer_data
SVC_DATA_PATH=/data
SVC_MOUNTS="/var/run/docker.sock:/var/run/docker.sock"
SVC_PULL=always
EPHEMERAL=false
