# Copy this file to local.nix and adjust for your machine:
#   cp local.nix.example local.nix
#
# Git identity is intentionally NOT configured here. It lives in a plain,
# non-Nix-managed file so you can change it without a rebuild:
#   git config -f ~/.config/git/config.local user.name  "Your Name"
#   git config -f ~/.config/git/config.local user.email "you@example.com"
{
  username = "romance";
  homeDirectory = "/home/romance";

  # Host role. Set to true on a "server" — a box that runs the distro's system
  # dockerd and should get the heavy docker/server tooling (docker CLI,
  # lazydocker, portainer). Leave false (the default) on client-only machines
  # (e.g. a WSL box that just SSHes out) so they stay lean. Only meaningful on
  # Linux; macOS gets docker via colima regardless. See flake.nix, home/packages.nix.
  # isServer = true;

  # WingTask cloud sync (Taskwarrior). Set this to your WingTask sync endpoint
  # to join the task-sync mesh on this host; leave it unset to skip cloud sync.
  # It doubles as the build-time gate for the sops secrets + sync services.
  #
  # The sensitive client_id + encryption_secret are NOT set here anymore — they
  # live encrypted in ./secrets.yaml (sops-nix) and are decrypted at activation
  # with this host's SSH key. To manage them: `sops secrets.yaml` (see
  # .sops.yaml, home/secrets.nix, docs/taskwarrior.md).
  # wingtaskServerUrl = "https://<your-wingtask-sync-endpoint>";
}
