# Like ./Dockerfile, but builds from your LOCAL WORKING TREE — uncommitted AND
# untracked files included — instead of cloning the committed branch. Lets you
# test WIP (the ^R fix, vendored home/yazi & home/starship, etc.) without pushing.
#
# Build context MUST be the repo root so COPY can see the whole repo:
#   docker build -f nix-test/Dockerfile.local -t hm-test-local .
#   docker run --rm -it hm-test-local
#
# /.dockerignore drops `.git`, so Nix treats the copy as a *path* flake and sees
# untracked files. Runs natively (the linux host's system double is rewritten to
# the build arch). Sandbox is off because Nix's seccomp can't load in this
# container; fine for a throwaway box.

FROM debian:bookworm-slim

ARG HM_HOST=romance@debian
ENV LANG=C.UTF-8 LC_ALL=C.UTF-8

RUN apt-get update && apt-get install -y --no-install-recommends \
        curl git xz-utils ca-certificates sudo procps \
    && rm -rf /var/lib/apt/lists/*

RUN useradd --create-home --shell /bin/bash romance \
    && echo 'romance ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/romance \
    && install -d -o romance -g romance -m 0755 /nix

RUN mkdir -p /etc/nix && printf '%s\n' \
        'experimental-features = nix-command flakes' \
        'sandbox = false' \
        'filter-syscalls = false' \
        'http2 = false' \
        'download-attempts = 5' \
    > /etc/nix/nix.conf

USER romance
WORKDIR /home/romance
ENV USER=romance HOME=/home/romance

# 1. Install Nix (single-user / --no-daemon)
RUN curl -L https://nixos.org/nix/install | sh -s -- --no-daemon

# 2. Copy the local working tree (no .git via /.dockerignore → path flake), then
#    rewrite the linux host's system double to the build arch for a native build.
COPY --chown=romance:romance . /home/romance/git/dotfiles
RUN rm -rf ~/git/dotfiles/.git \
    && sed -i "s/x86_64-linux/$(uname -m)-linux/g" ~/git/dotfiles/flake.nix

# 3. FULL activation from the local config
RUN . ~/.nix-profile/etc/profile.d/nix.sh \
    && cd ~/git/dotfiles \
    && nix run home-manager/master -- switch -b backup --flake ".#${HM_HOST}"

COPY --chown=romance:romance nix-test/entrypoint.sh /home/romance/entrypoint.sh
RUN chmod +x /home/romance/entrypoint.sh
ENTRYPOINT ["/home/romance/entrypoint.sh"]
